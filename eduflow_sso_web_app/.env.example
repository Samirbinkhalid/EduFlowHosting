# ──────────────────────────────────────────────────────────────────────────────
# Microsoft Entra ID (Azure AD) credentials
# Obtain these from the Azure Portal → App registrations → your app
# ──────────────────────────────────────────────────────────────────────────────

# Application (client) ID from the Azure App Registration
AZURE_CLIENT_ID=your-client-id-here

# Client secret value (not the secret ID) — create under Certificates & secrets
AZURE_CLIENT_SECRET=your-client-secret-here

# Tenant ID (Directory ID) for single-tenant apps.
# Use "common" to allow any Microsoft account (multi-tenant).
# Use "organizations" to allow any work/school account.
AZURE_TENANT_ID=your-tenant-id-here

# ──────────────────────────────────────────────────────────────────────────────
# App settings
# ──────────────────────────────────────────────────────────────────────────────

# Public base URL of this app — used to build the redirect URI
# Must exactly match one of the Redirect URIs registered in Azure Portal
APP_BASE_URL=http://localhost:8090

# A long random secret used to sign the session cookie
# Generate one with: python -c "import secrets; print(secrets.token_hex(32))"
SESSION_SECRET_KEY=change-me-use-a-long-random-string

# Set to "true" in production (cookie is HTTPS-only).
# Leave as "false" (or omit) for local HTTP development.
# HTTPS_ONLY=false

# Where to send the user after login / logout
POST_LOGIN_REDIRECT=/
POST_LOGOUT_REDIRECT=/

# ──────────────────────────────────────────────────────────────────────────────
# Storage paths  (optional — defaults work for `uv run serve` out of the box)
# In Docker these are overridden via the docker-compose.yml environment: block.
# ──────────────────────────────────────────────────────────────────────────────

# Directory for the SQLite database file (mentormind.db will be created here)
# DATA_DIR=./data

# Directory where extracted .m4a audio files are stored persistently
# UPLOADS_DIR=./uploads

# Temporary directory for in-progress TUS chunk assembly (safe to wipe on restart)
# TUS_UPLOADS_DIR=/tmp/tus_uploads

# Directory where transcription .txt files are stored persistently
# TRANSCRIPTIONS_DIR=./transcriptions

# ──────────────────────────────────────────────────────────────────────────────
# ElevenLabs  (required for transcription scheduler)
# Get your API key from https://elevenlabs.io → Profile → API Keys
# ──────────────────────────────────────────────────────────────────────────────

ELEVENLABS_API_KEY=your-elevenlabs-api-key-here

# ──────────────────────────────────────────────────────────────────────────────
# Transcription scheduler  (optional — defaults shown)
# ──────────────────────────────────────────────────────────────────────────────

# Number of consecutive ElevenLabs failures before a record is marked permanently
# failed (is_processed = -1) and removed from the retry queue.
# MAX_TRANSCRIPTION_RETRIES=3

# ──────────────────────────────────────────────────────────────────────────────
# Cloudflare R2  (required for sync scheduler — upload transcriptions to R2)
# Endpoint format: https://<account_id>.r2.cloudflarestorage.com
# Create an API token under R2 → Manage R2 API Tokens with Object Read & Write.
# ──────────────────────────────────────────────────────────────────────────────

R2_ENDPOINT_URL=https://<account_id>.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=your-r2-access-key-id-here
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key-here

# R2 bucket to write transcription objects into (flat key: {uuid}.txt)
# R2_BUCKET_NAME=mentormindweb-audio-uploads

# ──────────────────────────────────────────────────────────────────────────────
# Remote PostgreSQL  (required for sync scheduler — insert transcription rows)
# ──────────────────────────────────────────────────────────────────────────────

POSTGRES_HOST=your-postgres-host-here
POSTGRES_PASSWORD=your-postgres-password-here

# Optional overrides (defaults shown):
# POSTGRES_PORT=5432
# POSTGRES_DB=n8ndb
# POSTGRES_USER=root

# ──────────────────────────────────────────────────────────────────────────────
# Sync scheduler  (optional — defaults shown)
# ──────────────────────────────────────────────────────────────────────────────

# Number of consecutive R2/Postgres failures before a record is marked
# permanently failed (is_processed = -1) and removed from the retry queue.
# MAX_SYNC_RETRIES=3

# ──────────────────────────────────────────────────────────────────────────────
# Admin access  (optional — defaults to the Codeline admin address)
# Controls who may access the /dbstatus monitoring page.
# Comma-separated list of Microsoft SSO email addresses (case-insensitive).
# ──────────────────────────────────────────────────────────────────────────────

# ADMIN_EMAILS=syed.atyab@codeline.rihal.om
